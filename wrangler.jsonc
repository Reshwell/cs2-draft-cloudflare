{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cs2-draft-room",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-17",
  "vars": {
    "RCON_HOST": "1.14.22.237",
    "RCON_PORT": "27000",
    "GAME_SERVER_HOST": "cd.csgo2.icu",
    "GAME_SERVER_PORT": "27000",
    "PUBLIC_ORIGIN": "https://pick.noyy.de"
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "DraftRoom"
      },
      {
        "name": "DIRECTORY",
        "class_name": "RoomDirectory"
      }
    ]
  },
  "exports": {
    "DraftRoom": {
      "type": "durable-object",
      "storage": "sqlite"
    },
    "RoomDirectory": {
      "type": "durable-object",
      "storage": "sqlite"
    }
  }
}
